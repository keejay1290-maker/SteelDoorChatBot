# Chatbot LLM provider. Defaults to "mock" so the demo runs with no key.
# Options: mock | groq | deepseek
LLM_PROVIDER=groq

# Groq (OpenAI-compatible). Recommended - fast and free-tier friendly.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# DeepSeek (OpenAI-compatible). Optional alternative.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Where to store captured enquiries (SQLite file path).
ENQUIRY_DB=enquiries.db
