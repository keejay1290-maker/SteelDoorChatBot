# SteelDoorAi — environment config
# Copy to .env and fill in your keys.
# 'mock' provider works with NO keys — safe for local dev and CI.

# LLM provider: mock | groq | deepseek
LLM_PROVIDER=mock

# Groq — free tier, fast. Get key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# DeepSeek — backup LLM (optional)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# SQLite path (relative to working directory)
ENQUIRY_DB=enquiries.db

# EMAIL-001 — Internal brief email (all optional; email skipped if not set)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASS=your_app_password
# EMAIL_FROM=Steel Door AI <noreply@yourdomain.com>
# SALES_EMAIL=sales@steeldoorcompany.co.uk
